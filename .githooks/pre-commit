#!/usr/bin/env bash
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

mapfile -t files < <(git diff --cached --name-only --diff-filter=ACMR | grep -E '^packages/.*\.(ts|tsx|vue)$' || true)

if [ "${#files[@]}" -eq 0 ]; then
  exit 0
fi

pnpm exec eslint --fix "${files[@]}"
git add "${files[@]}"
